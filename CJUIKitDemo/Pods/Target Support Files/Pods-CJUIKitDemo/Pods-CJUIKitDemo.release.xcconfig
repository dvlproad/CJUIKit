CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
EMBEDDED_CONTENT_CONTAINS_SWIFT = YES
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_ROOT}/Headers/Public" "${PODS_ROOT}/Headers/Public/AFNetworking" "${PODS_ROOT}/Headers/Public/CJBaseEffectKit" "${PODS_ROOT}/Headers/Public/CJBaseHelper" "${PODS_ROOT}/Headers/Public/CJBaseUIKit" "${PODS_ROOT}/Headers/Public/CJBaseUtil" "${PODS_ROOT}/Headers/Public/CJDataVientianeSDK" "${PODS_ROOT}/Headers/Public/CJFile" "${PODS_ROOT}/Headers/Public/CJFoundation" "${PODS_ROOT}/Headers/Public/CJPopupAction" "${PODS_ROOT}/Headers/Public/CJPopupView" "${PODS_ROOT}/Headers/Public/CQDemoKit" "${PODS_ROOT}/Headers/Public/CQDemoResource" "${PODS_ROOT}/Headers/Public/IQKeyboardManager" "${PODS_ROOT}/Headers/Public/MJExtension" "${PODS_ROOT}/Headers/Public/Mantle" "${PODS_ROOT}/Headers/Public/Masonry" "${PODS_ROOT}/Headers/Public/PinYin4Objc" "${PODS_ROOT}/Headers/Public/SAMKeychain" "${PODS_ROOT}/Headers/Public/Shimmer" "${PODS_ROOT}/Headers/Public/UINavigation-SXFixSpace" "${PODS_ROOT}/Headers/Public/YYText"
LIBRARY_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/AFNetworking" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseEffectKit" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit-Swift" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUtil" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUtil-Swift" "${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK" "${PODS_CONFIGURATION_BUILD_DIR}/CJFile" "${PODS_CONFIGURATION_BUILD_DIR}/CJFoundation" "${PODS_CONFIGURATION_BUILD_DIR}/CJPopupAction" "${PODS_CONFIGURATION_BUILD_DIR}/CJPopupView" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource" "${PODS_CONFIGURATION_BUILD_DIR}/IQKeyboardManager" "${PODS_CONFIGURATION_BUILD_DIR}/MJExtension" "${PODS_CONFIGURATION_BUILD_DIR}/Mantle" "${PODS_CONFIGURATION_BUILD_DIR}/Masonry" "${PODS_CONFIGURATION_BUILD_DIR}/PinYin4Objc" "${PODS_CONFIGURATION_BUILD_DIR}/SAMKeychain" "${PODS_CONFIGURATION_BUILD_DIR}/Shimmer" "${PODS_CONFIGURATION_BUILD_DIR}/UINavigation-SXFixSpace" "${PODS_CONFIGURATION_BUILD_DIR}/YYText" "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_CFLAGS = $(inherited) -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit-Swift/CJBaseUIKit_Swift.modulemap" -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUtil-Swift/CJBaseUtil_Swift.modulemap" -isystem "${PODS_ROOT}/Headers/Public" -isystem "${PODS_ROOT}/Headers/Public/AFNetworking" -isystem "${PODS_ROOT}/Headers/Public/CJBaseEffectKit" -isystem "${PODS_ROOT}/Headers/Public/CJBaseHelper" -isystem "${PODS_ROOT}/Headers/Public/CJBaseUIKit" -isystem "${PODS_ROOT}/Headers/Public/CJDataVientianeSDK" -isystem "${PODS_ROOT}/Headers/Public/CJBaseUtil" -isystem "${PODS_ROOT}/Headers/Public/PinYin4Objc" -isystem "${PODS_ROOT}/Headers/Public/SAMKeychain" -isystem "${PODS_ROOT}/Headers/Public/CJFile" -isystem "${PODS_ROOT}/Headers/Public/CJFoundation" -isystem "${PODS_ROOT}/Headers/Public/CJPopupAction" -isystem "${PODS_ROOT}/Headers/Public/CJPopupView" -isystem "${PODS_ROOT}/Headers/Public/CQDemoKit" -isystem "${PODS_ROOT}/Headers/Public/Masonry" -isystem "${PODS_ROOT}/Headers/Public/CQDemoResource" -isystem "${PODS_ROOT}/Headers/Public/IQKeyboardManager" -isystem "${PODS_ROOT}/Headers/Public/MJExtension" -isystem "${PODS_ROOT}/Headers/Public/Mantle" -isystem "${PODS_ROOT}/Headers/Public/Shimmer" -isystem "${PODS_ROOT}/Headers/Public/UINavigation-SXFixSpace" -isystem "${PODS_ROOT}/Headers/Public/YYText"
OTHER_LDFLAGS = $(inherited) -ObjC -l"AFNetworking" -l"CJBaseEffectKit" -l"CJBaseHelper" -l"CJBaseUIKit" -l"CJBaseUIKit-Swift" -l"CJBaseUtil" -l"CJBaseUtil-Swift" -l"CJDataVientianeSDK" -l"CJFile" -l"CJFoundation" -l"CJPopupAction" -l"CJPopupView" -l"CQDemoKit" -l"CQDemoResource" -l"IQKeyboardManager" -l"MJExtension" -l"Mantle" -l"Masonry" -l"PinYin4Objc" -l"SAMKeychain" -l"Shimmer" -l"UINavigation-SXFixSpace" -l"YYText" -framework "AVFoundation" -framework "Accelerate" -framework "CoreFoundation" -framework "CoreGraphics" -framework "CoreLocation" -framework "CoreText" -framework "Foundation" -framework "MobileCoreServices" -framework "Photos" -framework "QuartzCore" -framework "Security" -framework "UIKit" -framework "WebKit"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/AFNetworking" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseEffectKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit-Swift" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUtil" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUtil-Swift" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJDataVientianeSDK" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJFile" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJFoundation" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJPopupAction" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJPopupView" "-F${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource" "-F${PODS_CONFIGURATION_BUILD_DIR}/IQKeyboardManager" "-F${PODS_CONFIGURATION_BUILD_DIR}/MJExtension" "-F${PODS_CONFIGURATION_BUILD_DIR}/Mantle" "-F${PODS_CONFIGURATION_BUILD_DIR}/Masonry" "-F${PODS_CONFIGURATION_BUILD_DIR}/PinYin4Objc" "-F${PODS_CONFIGURATION_BUILD_DIR}/SAMKeychain" "-F${PODS_CONFIGURATION_BUILD_DIR}/Shimmer" "-F${PODS_CONFIGURATION_BUILD_DIR}/UINavigation-SXFixSpace" "-F${PODS_CONFIGURATION_BUILD_DIR}/YYText"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit-Swift/CJBaseUIKit_Swift.modulemap" -Xcc -fmodule-map-file="${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUtil-Swift/CJBaseUtil_Swift.modulemap"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
SWIFT_INCLUDE_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit-Swift" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUtil-Swift"
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
