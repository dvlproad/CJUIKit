{
  "name": "CJBaseUIKit-Swift",
  "version": "0.0.4",
  "summary": "自定义的基础UI",
  "homepage": "https://github.com/dvlproad/CJUIKit",
  "description": "自定义的基础UI，可按需独立引入：\n• CJBaseUIKit-Swift/String - 字符串：获取字符串的方法\n• CJBaseUIKit-Swift/Color - 颜色：用来通过十六进制来设置颜色。 支持@“#123456”、 @“0X123456”、 @“123456”三种格式\n• CJBaseUIKit-Swift/UIView - UIView\n• CJBaseUIKit-Swift/UIView/adapt - 自适应宽高字体等\n• CJBaseUIKit-Swift/UIView/as - SwiftUI 与 UIKit 互转的方法\n• CJBaseUIKit-Swift/UIView/appear - 生命周期\n• CJBaseUIKit-Swift/UIView/CJPopupAction - 视图弹窗：UIView的类别，用来实现UIView弹出popupView的一个Uiew的类别\n• CJBaseUIKit-Swift/CJAlert - Alert\n\n每个子库可独立引入，详见各子库描述。",
  "license": "MIT",
  "authors": {
    "dvlproad": ""
  },
  "platforms": {
    "ios": "10.0"
  },
  "source": {
    "git": "https://github.com/dvlproad/CJUIKit.git",
    "tag": "CJBaseUIKit-Swift_0.0.4"
  },
  "frameworks": "UIKit",
  "swift_versions": "5.0",
  "requires_arc": true,
  "subspecs": [
    {
      "name": "String",
      "source_files": "CJBaseUIKit-Swift/String/**/*.{swift}"
    },
    {
      "name": "Color",
      "source_files": "CJBaseUIKit-Swift/Color/**/*.{swift}",
      "dependencies": {
        "CJBaseUIKit-Swift/String": []
      }
    },
    {
      "name": "UIView",
      "subspecs": [
        {
          "name": "adapt",
          "source_files": "CJBaseUIKit-Swift/UIView/adapt/**/*.{swift}"
        },
        {
          "name": "as",
          "source_files": "CJBaseUIKit-Swift/UIView/as/**/*.{swift}"
        },
        {
          "name": "appear",
          "source_files": "CJBaseUIKit-Swift/UIView/appear/**/*.{swift}"
        },
        {
          "name": "CJPopupAction",
          "source_files": "CJBaseUIKit-Swift/UIView/CJPopupAction/**/*.{swift}"
        }
      ]
    }
  ],
  "swift_version": "5.0"
}
