  },
  "frameworks": "UIKit",
  "requires_arc": true,
  "source_files": "TSDemo_BaseUIKit/**/*.{h,m}",
  "resource_bundles": {
    "TSDemo_BaseUIKit": [
      "TSDemo_BaseUIKit/**/*.xib"
    ]
  },
