{
  "name": "CJDataVientianeSDK",
  "version": "0.0.2",
  "summary": "数据万象SDK",
  "homepage": "https://github.com/dvlproad/CJUIKit",
  "license": "MIT",
  "authors": "dvlproad",
  "description": "Demo，可按需独立引入：\n• CJDataVientianeSDK/CJSubStringUtil - 指定位置、指定范围、最大长度字符串获取的方法\n• CJDataVientianeSDK/UITextInputLimitCJHelper - 复制粘贴新字符串获取的方法\n• CJDataVientianeSDK/UITextInputHeightCJHelper - 文本在指定宽度下的高度计算\n• CJDataVientianeSDK/NSCalendarCJHelper - NSCalendar帮助类\n\n每个子库可独立引入，详见各子库描述。",
  "platforms": {
    "ios": "9.0"
  },
  "swift_versions": "5.0",
  "source": {
    "git": "https://github.com/dvlproad/CJUIKit",
    "tag": "CJDataVientianeSDK_0.0.2"
  },
  "frameworks": "UIKit",
  "requires_arc": true,
  "subspecs": [
    {
      "name": "CJSubStringUtil",
      "source_files": "CJDataVientianeSDK/CJSubStringUtil/**/*.{h,m}"
    },
    {
      "name": "UITextInputLimitCJHelper",
      "source_files": "CJDataVientianeSDK/UITextInputLimitCJHelper/**/*.{h,m}",
      "dependencies": {
        "CJDataVientianeSDK/CJSubStringUtil": []
      }
    },
    {
      "name": "UITextInputHeightCJHelper",
      "source_files": "CJDataVientianeSDK/UITextInputHeightCJHelper/**/*.{h,m}"
    },
    {
      "name": "NSCalendarCJHelper",
      "source_files": "CJDataVientianeSDK/NSCalendarCJHelper/**/*.{h,m}"
    }
  ],
  "swift_version": "5.0"
}
