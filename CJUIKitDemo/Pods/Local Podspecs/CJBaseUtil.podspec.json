{
  "name": "CJBaseUtil",
  "version": "0.5.1",
  "summary": "自定义的基础工具类",
  "homepage": "https://github.com/dvlproad/CJUIKit",
  "license": "MIT",
  "authors": "dvlproad",
  "description": "自定义的基础工具类，可按需独立引入：\n• CJBaseUtil/CJIndentedStringUtil - 将 字符串/字典/数组转成含缩进字符串的字符串 的工具\n• CJBaseUtil/CJAppLastUtil - APP上次信息+账号安全工具\n• CJBaseUtil/CJDataUtil - 包含排序+SortOrder、分类+SortCategory、搜索+NormalSearch 等的数据处理工具类\n• CJBaseUtil/CJDecimalUtil - 小数的处理（常用于价钱Money、距离Distance的计算)\n• CJBaseUtil/CJDateUtil - 日期工具\n• CJBaseUtil/CJKeyboardUtil - 键盘工具\n• CJBaseUtil/CJCallUtil - 拨打电话工具\n• CJBaseUtil/CJQRCodeUtil - 二维码工具\n• CJBaseUtil/CJLaunchImageUtil - 启动图工具\n• CJBaseUtil/CJManager - 其他各种管理器(AppDelegate瘦身、位置变化、倒计时、悬浮框)\n• CJBaseUtil/CJManager/CJModuleManager - AppDelegate瘦身管理器\n• CJBaseUtil/CJManager/CJLocationChangeManager - 位置变化管理器\n• CJBaseUtil/CJManager/CJTimerManager - 倒计时管理器\n• CJBaseUtil/CJManager/CJSuspendWindowManager - 悬浮框管理器\n• CJBaseUtil/CJPinyinHelper - 拼音相关工具\n\n每个子库可独立引入，详见各子库描述。",
  "platforms": {
    "ios": "8.0"
  },
  "source": {
    "git": "https://github.com/dvlproad/CJUIKit.git",
    "tag": "CJBaseUtil_0.5.1"
  },
  "frameworks": "UIKit",
  "requires_arc": true,
  "subspecs": [
    {
      "name": "CJIndentedStringUtil",
      "source_files": "CJBaseUtil/CJIndentedStringUtil/**/*.{h,m}"
    },
    {
      "name": "CJAppLastUtil",
      "source_files": "CJBaseUtil/CJAppLastUtil/**/*.{h,m}",
      "dependencies": {
        "SAMKeychain": []
      }
    },
    {
      "name": "CJDataUtil",
      "source_files": "CJBaseUtil/CJDataUtil/**/*.{h,m}"
    },
    {
      "name": "CJDecimalUtil",
      "source_files": "CJBaseUtil/CJDecimalUtil/**/*.{h,m}"
    },
    {
      "name": "CJDateUtil",
      "source_files": "CJBaseUtil/CJDateUtil/**/*.{h,m}"
    },
    {
      "name": "CJKeyboardUtil",
      "source_files": "CJBaseUtil/CJKeyboardUtil/**/*.{h,m}"
    },
    {
      "name": "CJCallUtil",
      "source_files": "CJBaseUtil/CJCallUtil/**/*.{h,m}"
    },
    {
      "name": "CJQRCodeUtil",
      "source_files": "CJBaseUtil/CJQRCodeUtil/**/*.{h,m}"
    },
    {
      "name": "CJLaunchImageUtil",
      "source_files": "CJBaseUtil/CJLaunchImageUtil/**/*.{h,m}"
    },
    {
      "name": "CJManager",
      "subspecs": [
        {
          "name": "CJModuleManager",
          "source_files": "CJBaseUtil/CJManager/CJModuleManager/**/*.{h,m}"
        },
        {
          "name": "CJLocationChangeManager",
          "source_files": "CJBaseUtil/CJManager/CJLocationChangeManager/**/*.{h,m}",
          "dependencies": {
            "CJBaseUtil/CJDateUtil": []
          }
        },
        {
          "name": "CJTimerManager",
          "source_files": "CJBaseUtil/CJManager/CJTimerManager/**/*.{h,m}"
        },
        {
          "name": "CJSuspendWindowManager",
          "source_files": "CJBaseUtil/CJManager/CJSuspendWindowManager/**/*.{h,m}"
        },
        {
          "name": "CJConfuseManager",
          "source_files": "CJBaseUtil/CJManager/CJConfuseManager/**/*.{h,m}"
        }
      ]
    },
    {
      "name": "CJPinyinHelper",
      "source_files": "CJBaseUtil/CJPinyinHelper/**/*.{h,m}",
      "dependencies": {
        "PinYin4Objc": []
      }
    }
  ]
}
