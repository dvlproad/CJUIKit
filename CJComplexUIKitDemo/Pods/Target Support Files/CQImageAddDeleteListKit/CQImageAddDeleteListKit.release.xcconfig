CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
CONFIGURATION_BUILD_DIR = ${PODS_CONFIGURATION_BUILD_DIR}/CQImageAddDeleteListKit
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseHelper" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUtil-Swift" "${PODS_CONFIGURATION_BUILD_DIR}/CJCollectionViewLayout" "${PODS_CONFIGURATION_BUILD_DIR}/CJContainer" "${PODS_CONFIGURATION_BUILD_DIR}/CJFile" "${PODS_CONFIGURATION_BUILD_DIR}/CJImagePickerKit" "${PODS_CONFIGURATION_BUILD_DIR}/CJNetworkFileModel" "${PODS_CONFIGURATION_BUILD_DIR}/CJOverlayView" "${PODS_CONFIGURATION_BUILD_DIR}/CJPopupCreater" "${PODS_CONFIGURATION_BUILD_DIR}/CQActionCollectionView" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" "${PODS_CONFIGURATION_BUILD_DIR}/CQImageKit" "${PODS_CONFIGURATION_BUILD_DIR}/CQImagePickerKit" "${PODS_CONFIGURATION_BUILD_DIR}/CQOverlayKit" "${PODS_CONFIGURATION_BUILD_DIR}/CQPopupCreater_Base" "${PODS_CONFIGURATION_BUILD_DIR}/MBProgressHUD" "${PODS_CONFIGURATION_BUILD_DIR}/Masonry" "${PODS_CONFIGURATION_BUILD_DIR}/SDWebImage"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
OTHER_LDFLAGS = $(inherited) -framework "CJBaseHelper" -framework "CJFile" -framework "CJImagePickerKit" -framework "CJNetworkFileModel" -framework "CQActionCollectionView" -framework "CQImagePickerKit" -framework "CQOverlayKit" -framework "UIKit"
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_DEVELOPMENT_LANGUAGE = ${DEVELOPMENT_LANGUAGE}
PODS_ROOT = ${SRCROOT}
PODS_TARGET_SRCROOT = ${PODS_ROOT}/CQImageAddDeleteListKit
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
PRODUCT_BUNDLE_IDENTIFIER = org.cocoapods.${PRODUCT_NAME:rfc1034identifier}
SKIP_INSTALL = YES
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
