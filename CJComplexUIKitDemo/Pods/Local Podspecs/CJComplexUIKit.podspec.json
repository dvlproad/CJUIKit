{
  "name": "CJComplexUIKit",
  "version": "0.4.0",
  "summary": "自定义的稍微复杂的UI( 内部有 CJUploadImageCollectionView 依赖到了私有的 CQImageAddDeleteListKit )",
  "homepage": "https://github.com/dvlproad/CJUIKit",
  "description": "自定义的稍微复杂的UI( 内部有 CJUploadImageCollectionView 依赖到了私有的 CQImageAddDeleteListKit )，可按需独立引入：\n• CJComplexUIKit/CJBaseCollectionViewCell - 集合单元格\n• CJComplexUIKit/CJUploadImageCollectionView - 图片选择及上传视图( 内部有 CJUploadImageCollectionView 依赖到了私有的 CQImageAddDeleteListKit )\n\n每个子库可独立引入，详见各子库描述。",
  "license": "MIT",
  "authors": {
    "dvlproad": ""
  },
  "platforms": {
    "ios": "9.0"
  },
  "source": {
    "git": "https://github.com/dvlproad/CJUIKit.git",
    "tag": "CJComplexUIKit_0.4.0"
  },
  "frameworks": "UIKit",
  "requires_arc": true,
  "subspecs": [
    {
      "name": "CJBaseCollectionViewCell",
      "source_files": "CJComplexUIKit/CJBaseCollectionViewCell/**/*.{h,m}"
    },
    {
      "name": "CJUploadImageCollectionView",
      "source_files": "CJComplexUIKit/CJUploadImageCollectionView/**/*.{h,m}",
      "resource_bundles": {
        "CJComplexUIKit_ImagePickerCollectionlView": [
          "CJComplexUIKit/CJUploadImageCollectionView/**/*.{png,xib,bundle}"
        ]
      },
      "frameworks": "MediaPlayer",
      "dependencies": {
        "JGActionSheet": [],
        "CJComplexUIKit/CJBaseCollectionViewCell": [],
        "CQImageAddDeleteListKit/AddDeletePickUpload": [],
        "CJNetwork/AFNetworkingUploadComponent": []
      }
    }
  ]
}
