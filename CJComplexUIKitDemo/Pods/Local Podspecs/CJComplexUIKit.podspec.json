{
  "name": "CJComplexUIKit",
  "version": "0.4.0",
  "summary": "自定义的稍微复杂的UI( 内部有 CJUploadImageCollectionView 依赖到了私有的 CQImageAddDeleteListKit )",
  "homepage": "https://github.com/dvlproad/CJUIKit",
  "description": "自定义的稍微复杂的UI，可按需独立引入：\n• CJComplexUIKit/CJCollectionView/CJBaseCollectionViewCell - 集合单元格\n• CJComplexUIKit/CJDataScrollView/ImagePickerCollectionlView - 图片选择集合视图\n\n每个子库可独立引入，详见各子库描述。",
  "license": "MIT",
  "authors": {
    "dvlproad": ""
  },
  "platforms": {
    "ios": "9.0"
  },
  "source": {
    "git": "https://github.com/dvlproad/CJUIKit.git",
    "tag": "CJComplexUIKit_0.4.0"
  },
  "frameworks": "UIKit",
  "requires_arc": true,
  "subspecs": [
    {
      "name": "CJCollectionView",
      "subspecs": [
        {
          "name": "CJBaseCollectionViewCell",
          "source_files": "CJComplexUIKit/CJCollectionView/CJBaseCollectionViewCell/**/*.{h,m}"
        }
      ]
    },
    {
      "name": "CJDataScrollView",
      "subspecs": [
        {
          "name": "ImagePickerCollectionlView",
          "source_files": "CJComplexUIKit/CJDataScrollView/ImagePickerCollectionlView/**/*.{h,m}",
          "resource_bundles": {
            "CJComplexUIKit_ImagePickerCollectionlView": [
              "CJComplexUIKit/CJDataScrollView/ImagePickerCollectionlView/**/*.{png,xib,bundle}"
            ]
          },
          "frameworks": "MediaPlayer",
          "dependencies": {
            "JGActionSheet": [],
            "CJComplexUIKit/CJCollectionView/CJBaseCollectionViewCell": [],
            "CQImageAddDeleteListKit/AddDeletePickUpload": [],
            "CJNetwork/AFNetworkingUploadComponent": []
          }
        }
      ]
    }
  ]
}
